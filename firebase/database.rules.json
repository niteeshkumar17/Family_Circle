{
  "rules": {
    ".read": false,
    ".write": false,
    
    "locations": {
      "$familyId": {
        ".read": "auth != null",
        "$userId": {
          ".write": "auth != null && auth.uid == $userId",
          ".validate": "newData.hasChildren(['latitude', 'longitude', 'timestamp']) && newData.child('latitude').isNumber() && newData.child('longitude').isNumber() && newData.child('timestamp').isNumber()"
        }
      }
    },
    
    "presence": {
      "$userId": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid == $userId"
      }
    },
    
    "sos_active": {
      "$familyId": {
        ".read": "auth != null",
        "$eventId": {
          ".write": "auth != null"
        }
      }
    },
    
    "family_members": {
      "$familyId": {
        ".read": "auth != null",
        "$userId": {
          ".write": "auth != null && auth.uid == $userId"
        }
      }
    },
    
    "typing_indicators": {
      "$familyId": {
        ".read": "auth != null",
        "$userId": {
          ".write": "auth != null && auth.uid == $userId"
        }
      }
    }
  }
}
